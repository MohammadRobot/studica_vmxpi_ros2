#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

changed_files="$(git diff --cached --name-only)"

if ! grep -Eq '^(bringup/config/profiles/|bringup/config/profile_template/|bringup/launch/|scripts/validate_profiles.py|scripts/check_project.sh|\.githooks/pre-commit)' <<<"$changed_files"; then
  exit 0
fi

echo "[pre-commit] Running project checks..."
"${repo_root}/scripts/check_project.sh"
