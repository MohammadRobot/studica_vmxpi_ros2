#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

changed_files="$(git diff --cached --name-only)"

if ! grep -Eq '^(bringup/config/profiles/|bringup/config/profile_template/|scripts/validate_profiles.py|bringup/launch/bringup.launch.py)' <<<"$changed_files"; then
  exit 0
fi

echo "[pre-commit] Running profile validation..."
python3 "${repo_root}/scripts/validate_profiles.py" --profiles-dir "${repo_root}/bringup/config/profiles"
