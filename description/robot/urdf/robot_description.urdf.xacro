<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="robot_description" params="prefix base_mass:=10.0 base_width:=0.4 base_length:=0.4 base_height:=0.1 wheel_mass:=0.3 wheel_len:=0.04 wheel_radius:=0.05 wheel_z_offset:=-0.027 caster_wheel_mass:=0.1 caster_wheel_radius:=0.05 laser1_model_x:=0.192 laser_model_z:=0.0 laser_frame_z:=0.03 wheel_layout:=diff">

    <!-- Constants for robot dimensions -->
    <xacro:property name="PI" value="3.1415926535897931"/>
    <!-- <xacro:property name="z_offset" value="${wheel_z_offset}"/> -->
    <xacro:property name="wheel_layout_resolved" value="${wheel_layout if wheel_layout in ['diff', 'diff_4wd', 'mecanum', 'omni'] else 'diff'}"/>
    <xacro:property name="front_left_wheel_yaw" value="${-PI/4 if wheel_layout_resolved == 'omni' else 0.0}"/>
    <xacro:property name="front_right_wheel_yaw" value="${PI/4 if wheel_layout_resolved == 'omni' else 0.0}"/>
    <xacro:property name="rear_left_wheel_yaw" value="${PI/4 if wheel_layout_resolved == 'omni' else 0.0}"/>
    <xacro:property name="rear_right_wheel_yaw" value="${-PI/4 if wheel_layout_resolved == 'omni' else 0.0}"/>
    <!-- Keep base_link/base_footprint on the ground plane. -->
    <xacro:property name="base_to_chassis_z" value="${float(wheel_radius) - float(wheel_z_offset)}"/>
    
    <xacro:if value="${wheel_layout_resolved == 'diff'}">
      <xacro:property name="robot_frame_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/frames/robot_frame_4wd.dae"/>
      <xacro:property name="left_wheel_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/wheels/drive_wheel.dae"/>
      <xacro:property name="right_wheel_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/wheels/drive_wheel.dae"/>
    </xacro:if>
    <xacro:if value="${wheel_layout_resolved == 'diff_4wd'}">
      <xacro:property name="robot_frame_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/frames/robot_frame_4wd.dae"/>
      <xacro:property name="left_wheel_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/wheels/76249RW.dae"/>
      <xacro:property name="right_wheel_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/wheels/76249RW.dae"/>
    </xacro:if>
    <xacro:if value="${wheel_layout_resolved == 'mecanum'}">
      <xacro:property name="robot_frame_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/frames/robot_frame_4wd.dae"/>
      <xacro:property name="left_wheel_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/wheels/mecanum_left_wheel.dae"/>
      <xacro:property name="right_wheel_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/wheels/mecanum_right_wheel.dae"/>
    </xacro:if>
    <xacro:if value="${wheel_layout_resolved == 'omni'}">
      <xacro:property name="robot_frame_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/frames/ws_robot_base_x_drive.dae"/>
      <xacro:property name="left_wheel_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/wheels/omni_wheel_v2.dae"/>
      <xacro:property name="right_wheel_mesh_file" value="package://studica_vmxpi_ros2/description/meshes/wheels/omni_wheel_v2.dae"/>
    </xacro:if>


    <link name="${prefix}base_link"/>

    <!-- Base Link -->
    <link name="${prefix}chassis_link">
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <!-- Keep collision primitive simple/stable for physics engines (DART). -->
          <box size="${base_length - wheel_len} ${base_width - wheel_len} ${base_height}"/>
        </geometry>
      </collision>

      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <!-- <box size="${base_length} ${base_width} ${base_height}"/> -->
          <mesh filename="${robot_frame_mesh_file}" scale="1.0 1.0 1.0"/>
        </geometry>
        <!-- <material name="orange"/> -->
      </visual>

      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${base_mass}"/>
        <inertia
          ixx="${base_mass / 12.0 * (base_length*base_length + base_height*base_height)}" ixy="0.0" ixz="0.0"
          iyy="${base_mass / 12.0 * (base_height*base_height + base_width*base_width)}" iyz="0.0"
          izz="${base_mass / 12.0 * (base_width*base_width + base_length*base_length)}"/>
      </inertial>
    </link>

    <joint name="${prefix}base_link_joint" type="fixed">
      <origin rpy="0 0 0" xyz="0 0 ${base_to_chassis_z}"/>
      <parent link="${prefix}base_link"/>
      <child link="${prefix}chassis_link"/>
    </joint>

    <xacro:if value="${wheel_layout_resolved == 'diff'}">
      <joint name="${prefix}left_wheel_joint" type="continuous">
        <parent link="${prefix}chassis_link"/>
        <child link="${prefix}left_wheel"/>
        <origin xyz="${base_length/2} ${base_width/2} ${wheel_z_offset}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.05"/>
        <limit effort="100" velocity="20.0"/>
      </joint>

      <link name="${prefix}left_wheel">
        <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>

        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <geometry>
            <!-- <cylinder length="${wheel_len}" radius="${wheel_radius}"/> -->
            <mesh filename="${left_wheel_mesh_file}" scale="1.0 1.0 1.0"/>
          </geometry>
          <!-- <material name="black"/> -->
        </visual>

        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0.0" ixz="0.0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0.0"
            izz="${wheel_mass / 2.0 * wheel_radius*wheel_radius}"/>
        </inertial>
      </link>

      <joint name="${prefix}right_wheel_joint" type="continuous">
        <parent link="${prefix}chassis_link"/>
        <child link="${prefix}right_wheel"/>
        <origin xyz="${base_length/2} -${base_width/2} ${wheel_z_offset}" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.05"/>
        <limit effort="100" velocity="20.0"/>
      </joint>

      <link name="${prefix}right_wheel">
        <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>

        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <!-- <cylinder length="${wheel_len}" radius="${wheel_radius}"/> -->
            <mesh filename="${right_wheel_mesh_file}" scale="1.0 1.0 1.0"/>
          </geometry>
          <!-- <material name="black"/> -->
        </visual>

        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0.0" ixz="0.0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0.0"
            izz="${wheel_mass / 2.0 * wheel_radius*wheel_radius}"/>
        </inertial>
      </link>

      <joint name="${prefix}caster_left_wheel_joint" type="continuous">
        <parent link="${prefix}chassis_link"/>
        <child link="${prefix}caster_left_wheel"/>
        <origin xyz="${-base_length/2} ${base_width/2} ${wheel_z_offset}" rpy="0 0 ${rear_left_wheel_yaw}"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.05"/>
        <limit effort="100" velocity="20.0"/>
      </joint>

      <link name="${prefix}caster_left_wheel">
        <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>
        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <geometry>
            <!-- <cylinder length="${wheel_len}" radius="${wheel_radius}"/> -->
            <mesh filename="package://studica_vmxpi_ros2/description/meshes/wheels/omni_wheel_v2.dae" scale="1.0 1.0 1.0"/>
          </geometry>
          <!-- <material name="black"/> -->
        </visual>
        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0.0" ixz="0.0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0.0"
            izz="${wheel_mass / 2.0 * wheel_radius*wheel_radius}"/>
        </inertial>
      </link>

      <joint name="${prefix}caster_right_wheel_joint" type="continuous">
        <parent link="${prefix}chassis_link"/>
        <child link="${prefix}caster_right_wheel"/>
        <origin xyz="${-base_length/2} -${base_width/2} ${wheel_z_offset}" rpy="0 0 ${rear_right_wheel_yaw}"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.05"/>
        <limit effort="100" velocity="20.0"/>     
      </joint>

      <link name="${prefix}caster_right_wheel">
         <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>
        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <!-- <cylinder length="${wheel_len}" radius="${wheel_radius}"/> -->
            <mesh filename="package://studica_vmxpi_ros2/description/meshes/wheels/omni_wheel_v2.dae" scale="1.0 1.0 1.0"/>
          </geometry>
          <!-- <material name="black"/> -->
        </visual>
        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0.0" ixz="0.0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0.0"
            izz="${wheel_mass / 2.0 * wheel_radius*wheel_radius}"/>
        </inertial>
      </link>
    </xacro:if>

    <xacro:unless value="${wheel_layout_resolved == 'diff'}">
      <joint name="${prefix}front_left_wheel_joint" type="continuous">
        <parent link="${prefix}chassis_link"/>
        <child link="${prefix}front_left_wheel"/>
        <origin xyz="${base_length/2} ${base_width/2} ${wheel_z_offset}" rpy="0 0 ${front_left_wheel_yaw}"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.05"/>
        <limit effort="100" velocity="20.0"/>
      </joint>

      <link name="${prefix}front_left_wheel">
        <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>
        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <geometry>
            <!-- <cylinder length="${wheel_len}" radius="${wheel_radius}"/> -->
            <mesh filename="${left_wheel_mesh_file}" scale="1.0 1.0 1.0"/>
          </geometry>
          <!-- <material name="black"/> -->
        </visual>
        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0.0" ixz="0.0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0.0"
            izz="${wheel_mass / 2.0 * wheel_radius*wheel_radius}"/>
        </inertial>
      </link>

      <joint name="${prefix}front_right_wheel_joint" type="continuous">
        <parent link="${prefix}chassis_link"/>
        <child link="${prefix}front_right_wheel"/>
        <origin xyz="${base_length/2} -${base_width/2} ${wheel_z_offset}" rpy="0 0 ${front_right_wheel_yaw}"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.05"/>
        <limit effort="100" velocity="20.0"/>
      </joint>

      <link name="${prefix}front_right_wheel">
        <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>
        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <!-- <cylinder length="${wheel_len}" radius="${wheel_radius}"/> -->
            <mesh filename="${right_wheel_mesh_file}" scale="1.0 1.0 1.0"/>
          </geometry>
          <!-- <material name="black"/> -->
        </visual>
        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0.0" ixz="0.0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0.0"
            izz="${wheel_mass / 2.0 * wheel_radius*wheel_radius}"/>
        </inertial>
      </link>

      <joint name="${prefix}rear_left_wheel_joint" type="continuous">
        <parent link="${prefix}chassis_link"/>
        <child link="${prefix}rear_left_wheel"/>
        <origin xyz="${-base_length/2} ${base_width/2} ${wheel_z_offset}" rpy="0 0 ${rear_left_wheel_yaw}"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.05"/>
        <limit effort="100" velocity="20.0"/>
      </joint>

      <link name="${prefix}rear_left_wheel">
        <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>
        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <geometry>
            <!-- <cylinder length="${wheel_len}" radius="${wheel_radius}"/> -->
            <mesh filename="${right_wheel_mesh_file}" scale="1.0 1.0 1.0"/>
          </geometry>
          <!-- <material name="black"/> -->
        </visual>
        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 ${PI}"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0.0" ixz="0.0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0.0"
            izz="${wheel_mass / 2.0 * wheel_radius*wheel_radius}"/>
        </inertial>
      </link>

      <joint name="${prefix}rear_right_wheel_joint" type="continuous">
        <parent link="${prefix}chassis_link"/>
        <child link="${prefix}rear_right_wheel"/>
        <origin xyz="${-base_length/2} -${base_width/2} ${wheel_z_offset}" rpy="0 0 ${rear_right_wheel_yaw}"/>
        <axis xyz="0 1 0"/>
        <dynamics damping="0.05"/>
        <limit effort="100" velocity="20.0"/>
      </joint>

      <link name="${prefix}rear_right_wheel">
        <collision>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <cylinder length="${wheel_len}" radius="${wheel_radius}"/>
          </geometry>
        </collision>
        <visual>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <geometry>
            <!-- <cylinder length="${wheel_len}" radius="${wheel_radius}"/> -->
            <mesh filename="${left_wheel_mesh_file}" scale="1.0 1.0 1.0"/>
          </geometry>
          <!-- <material name="black"/> -->
        </visual>
        <inertial>
          <origin xyz="0 0 0" rpy="${PI/2} 0 0"/>
          <mass value="${wheel_mass}"/>
          <inertia
            ixx="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" ixy="0.0" ixz="0.0"
            iyy="${wheel_mass / 12.0 * (3*wheel_radius*wheel_radius + wheel_len*wheel_len)}" iyz="0.0"
            izz="${wheel_mass / 2.0 * wheel_radius*wheel_radius}"/>
        </inertial>
      </link>
    </xacro:unless>

    <link name="${prefix}laser_model_link">
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://studica_vmxpi_ros2/description/meshes/sensors/micro_lidar.dae" scale="1.0 1.0 1.0"/>
        </geometry>
      </visual>

      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://studica_vmxpi_ros2/description/meshes/sensors/micro_lidar.dae" scale="1.0 1.0 1.0"/>
        </geometry>
      </collision>

      <inertial>
        <mass value="0.01"/>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <inertia ixx="6.066578520833334e-06" ixy="0" ixz="0" iyy="6.072950163333333e-06" iyz="0" izz="9.365128684166666e-06"/>
      </inertial>
    </link>

    <joint name="${prefix}laser_scan_model_link_joint" type="fixed">
      <origin rpy="0 0 0" xyz="${laser1_model_x} 0 ${laser_model_z}"/>
      <parent link="${prefix}chassis_link"/>
      <child link="${prefix}laser_model_link"/>
      <axis xyz="0 0 0"/>
    </joint>

    <link name="${prefix}laser_scan_frame">
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </link>

    <joint name="${prefix}laser_scan_frame_joint" type="fixed">
      <origin rpy="0 0 0" xyz="0 0 ${laser_frame_z}"/>
      <parent link="${prefix}laser_model_link"/>
      <child link="${prefix}laser_scan_frame"/>
    </joint>

    <link name="${prefix}imu_link">
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </link>

    <joint name="${prefix}imu_link_joint" type="fixed">
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <parent link="${prefix}chassis_link"/>
      <child link="${prefix}imu_link"/>
    </joint>

  </xacro:macro>

</robot>
